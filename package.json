    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "framer-motion": "^12.23.25",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.556.0",
    "maath": "^0.10.8",
    "multer": "^2.0.2",
    "prisma": "^5.22.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.10.1",
    "three": "^0.181.2",
    "tsx": "^4.21.0",
    "zustand": "^5.0.9"
