# Reverse proxy / TLS
APP_DOMAIN=zagarami.com
ACME_EMAIL=ops@example.com

# Public app runtime
PORT=3001
CLIENT_URL=https://zagarami.com

# MySQL inside docker-compose.prod.yml
MYSQL_DATABASE=stones
MYSQL_USER=stones
MYSQL_PASSWORD=replace_with_strong_mysql_password
MYSQL_ROOT_PASSWORD=replace_with_strong_mysql_root_password

# Must point to the internal db service and match MYSQL_* above
DATABASE_URL=mysql://stones:replace_with_strong_mysql_password@db:3306/stones?connection_limit=20&pool_timeout=30

# Auth secrets
ACCESS_TOKEN_SECRET=replace_with_a_long_random_access_secret
REFRESH_TOKEN_SECRET=replace_with_a_long_random_refresh_secret
TELEGRAM_TOKEN_ENCRYPTION_KEY=replace_with_32_byte_or_longer_secret
# Optional auth tuning
# AUTH_ACCESS_TOKEN_TTL_MINUTES=10
# AUTH_REFRESH_SESSION_TTL_DAYS=30

# Worker
VIDEO_PROCESSOR_POLL_MS=3000
TELEGRAM_WORKER_POLL_MS=5000
TELEGRAM_WORKER_RETRY_BASE_MS=5000
TELEGRAM_WORKER_MAX_ATTEMPTS=5

# Frontend build-time / helper distribution (optional)
# Leave empty if the production DMG is not published yet.
VITE_VIDEO_HELPER_DOWNLOAD_URL=
VITE_VIDEO_HELPER_DOWNLOAD_URL_ARM64=

# Desktop helper packaging must allow the same public origin
STONES_HELPER_ALLOWED_ORIGIN=https://zagarami.com
