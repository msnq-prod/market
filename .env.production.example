# Reverse proxy / TLS
APP_DOMAIN=stones.example.com
ACME_EMAIL=ops@example.com

# Public app runtime
PORT=3001
CLIENT_URL=https://stones.example.com

# MySQL inside docker-compose.prod.yml
MYSQL_DATABASE=stones
MYSQL_USER=stones
MYSQL_PASSWORD=replace_with_strong_mysql_password
MYSQL_ROOT_PASSWORD=replace_with_strong_mysql_root_password

# Must point to the internal db service and match MYSQL_* above
DATABASE_URL=mysql://stones:replace_with_strong_mysql_password@db:3306/stones?connection_limit=20&pool_timeout=30

# Auth secrets
ACCESS_TOKEN_SECRET=replace_with_a_long_random_access_secret
REFRESH_TOKEN_SECRET=replace_with_a_long_random_refresh_secret

# Worker
VIDEO_PROCESSOR_POLL_MS=3000

# Frontend build-time / helper distribution
VITE_VIDEO_HELPER_DOWNLOAD_URL=https://downloads.example.com/Stones-Video-Helper.dmg

# Desktop helper packaging must allow the same public origin
STONES_HELPER_ALLOWED_ORIGIN=https://stones.example.com
