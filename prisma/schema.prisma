generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// --- Existing Models (Marketplace) ---

model Language {
  id             Int      @id @default(autoincrement())
  code           String   @unique
  name           String
  available      Boolean  @default(false)
  is_default     Boolean  @default(false)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  product_translations  ProductTranslation[]
  location_translations LocationTranslation[]
  category_translations CategoryTranslation[]

  @@map("languages")
}

model Category {
  id           String              @id @default(uuid())
  slug         String              @unique
  created_at   DateTime            @default(now())
  updated_at   DateTime            @updatedAt
  translations CategoryTranslation[]
  products     Product[]

  @@map("categories")
}

model CategoryTranslation {
  id          String   @id @default(uuid())
  category_id String
  language_id Int
  name        String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  category    Category @relation(fields: [category_id], references: [id])
  language    Language @relation(fields: [language_id], references: [id])

  @@index([category_id])
  @@index([language_id])
  @@unique([category_id, language_id])
  @@map("category_translations")
}

model Location {
  id           String                @id @default(uuid())
  lat          Float
  lng          Float
  image        String?
  created_at   DateTime              @default(now())
  updated_at   DateTime              @updatedAt
  products     Product[]
  translations LocationTranslation[]

  @@map("locations")
}

model LocationTranslation {
  id           String   @id @default(uuid())
  location_id  String
  language_id  Int
  name         String
  country      String
  description  String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  location     Location @relation(fields: [location_id], references: [id])
  language     Language @relation(fields: [language_id], references: [id])

  @@index([location_id])
  @@index([language_id])
  @@unique([location_id, language_id])
  @@map("location_translations")
}

model Product {
  id           String               @id @default(uuid())
  price        Decimal               @db.Decimal(10, 2)
  image        String
  location_id  String
  category_id  String
  created_at   DateTime              @default(now())
  updated_at   DateTime              @updatedAt

  location     Location             @relation(fields: [location_id], references: [id])
  category     Category             @relation(fields: [category_id], references: [id])
  translations ProductTranslation[]
  order_items  OrderItem[]

  @@index([location_id])
  @@index([category_id])
  @@map("products")
}

model ProductTranslation {
  id           String  @id @default(uuid())
  product_id   String
  language_id  Int
  name         String
  description  String
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  product      Product  @relation(fields: [product_id], references: [id])
  language     Language @relation(fields: [language_id], references: [id])

  @@index([product_id])
  @@index([language_id])
  @@unique([product_id, language_id])
  @@map("product_translations")
}

model Order {
  id         String      @id @default(uuid())
  user_id    String
  total      Decimal      @db.Decimal(12, 2)
  status     String      @default("PENDING")
  created_at DateTime    @default(now())
  updated_at DateTime    @updatedAt

  user       User        @relation(fields: [user_id], references: [id])
  items      OrderItem[]

  @@index([user_id])
  @@map("orders")
}

model OrderItem {
  id         String  @id @default(uuid())
  order_id   String
  product_id String
  quantity   Int
  price      Decimal @db.Decimal(10, 2)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  order      Order   @relation(fields: [order_id], references: [id])
  product    Product @relation(fields: [product_id], references: [id])

  @@index([order_id])
  @@index([product_id])
  @@map("order_items")
}

// --- New Models (Unique Item Tracking System) ---

enum Role {
  USER
  ADMIN
  MANAGER
  FRANCHISEE
}

enum BatchStatus {
  DRAFT
  TRANSIT
  RECEIVED
  ERROR
  FINISHED
}

enum ItemStatus {
  NEW
  REJECTED
  STOCK_HQ
  STOCK_ONLINE
  ON_CONSIGNMENT
  SOLD_ONLINE
  ACTIVATED
}

enum SalesChannel {
  OFFLINE_POINT
  MARKETPLACE
  DIRECT_SITE
}

enum LedgerOperation {
  ROYALTY_CHARGE
  SALES_PAYOUT
  WITHDRAWAL
  MANUAL_ADJ
}

enum CollectionRequestStatus {
  OPEN
  IN_PROGRESS
  FULFILLED
  CANCELLED
}

model User {
  id              String   @id @default(uuid())
  name            String
  email           String   @unique
  password_hash   String?
  role            Role     @default(USER)
  balance         Decimal  @default(0) @db.Decimal(12, 2)
  commission_rate Decimal  @default(0) @db.Decimal(5, 2)
  details         Json?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  
  // Relations
  orders          Order[]
  batches         Batch[]  @relation("BatchOwner")
  ledgers         Ledger[]
  audit_logs      AuditLog[]
  created_collection_requests CollectionRequest[] @relation("CollectionRequestCreatedBy")
  target_collection_requests  CollectionRequest[] @relation("CollectionRequestTargetUser")

  @@map("users")
}

model Batch {
  id          String      @id @default(uuid())
  owner_id    String
  video_url   String?
  gps_lat     Float?
  gps_lng     Float?
  status      BatchStatus @default(DRAFT)
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt

  owner       User        @relation("BatchOwner", fields: [owner_id], references: [id])
  items       Item[]

  @@index([owner_id])
  @@map("batches")
}

model Item {
  id              String        @id @default(uuid())
  batch_id        String
  temp_id         String        // Number on the package
  public_token    String        @unique // Hash for QR code
  photo_url       String
  status          ItemStatus    @default(NEW)
  sales_channel   SalesChannel?
  activation_date DateTime?
  price_sold      Decimal?      @db.Decimal(12, 2)
  commission_hq   Decimal?      @db.Decimal(12, 2)
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt

  batch           Batch         @relation(fields: [batch_id], references: [id])
  ledger_entries  Ledger[]

  // Constraint: temp_id should be unique within a batch? Ideally yes.
  @@unique([batch_id, temp_id])
  @@index([batch_id])
  @@index([public_token])
  @@map("items")
}

model Ledger {
  id          String          @id @default(uuid())
  user_id     String
  item_id     String?
  operation   LedgerOperation
  amount      Decimal         @db.Decimal(12, 2)
  timestamp   DateTime        @default(now())

  user        User            @relation(fields: [user_id], references: [id])
  item        Item?           @relation(fields: [item_id], references: [id])

  @@index([user_id])
  @@map("ledger")
}

model AuditLog {
  id          String   @id @default(uuid())
  user_id     String
  action      String
  details     Json?
  timestamp   DateTime @default(now())

  user        User     @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@map("audit_logs")
}

model ContentPage {
  id          String   @id @default(uuid())
  key         String   @unique
  data        Json
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("content_pages")
}

model CollectionRequest {
  id              String                  @id @default(uuid())
  created_by      String
  target_user_id  String?
  title           String
  note            String?
  requested_qty   Int
  status          CollectionRequestStatus @default(OPEN)
  created_at      DateTime                @default(now())
  updated_at      DateTime                @updatedAt

  created_by_user User                    @relation("CollectionRequestCreatedBy", fields: [created_by], references: [id])
  target_user     User?                   @relation("CollectionRequestTargetUser", fields: [target_user_id], references: [id])

  @@index([created_by])
  @@index([target_user_id])
  @@index([status])
  @@index([created_at])
  @@map("collection_requests")
}
