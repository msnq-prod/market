generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// --- Existing Models (Marketplace) ---

model Language {
  id         Int      @id @default(autoincrement())
  code       String   @unique
  name       String
  available  Boolean  @default(false)
  is_default Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  product_translations  ProductTranslation[]
  location_translations LocationTranslation[]
  category_translations CategoryTranslation[]

  @@map("languages")
}

model Category {
  id           String                @id @default(uuid())
  slug         String                @unique
  created_at   DateTime              @default(now())
  updated_at   DateTime              @updatedAt
  translations CategoryTranslation[]
  products     Product[]

  @@map("categories")
}

model CategoryTranslation {
  id          String   @id @default(uuid())
  category_id String
  language_id Int
  name        String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  category Category @relation(fields: [category_id], references: [id])
  language Language @relation(fields: [language_id], references: [id])

  @@unique([category_id, language_id])
  @@index([category_id])
  @@index([language_id])
  @@map("category_translations")
}

model Location {
  id           String                @id @default(uuid())
  lat          Float
  lng          Float
  image        String?
  created_at   DateTime              @default(now())
  updated_at   DateTime              @updatedAt
  products     Product[]
  translations LocationTranslation[]

  @@map("locations")
}

model LocationTranslation {
  id          String   @id @default(uuid())
  location_id String
  language_id Int
  name        String
  country     String
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  location Location @relation(fields: [location_id], references: [id])
  language Language @relation(fields: [language_id], references: [id])

  @@unique([location_id, language_id])
  @@index([location_id])
  @@index([language_id])
  @@map("location_translations")
}

model Product {
  id                   String   @id @default(uuid())
  price                Decimal  @db.Decimal(10, 2)
  image                String
  wildberries_url      String?
  ozon_url             String?
  location_id          String
  category_id          String
  country_code         String   @default("RUS") @db.VarChar(3)
  location_code        String   @default("LOC") @db.VarChar(3)
  item_code            String   @default("00") @db.VarChar(8)
  location_description String?  @db.Text
  is_published         Boolean  @default(false)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  location            Location             @relation(fields: [location_id], references: [id])
  category            Category             @relation(fields: [category_id], references: [id])
  translations        ProductTranslation[]
  order_items         OrderItem[]
  collection_requests CollectionRequest[]
  batches             Batch[]
  items               Item[]

  @@index([location_id])
  @@index([category_id])
  @@index([is_published])
  @@map("products")
}

model ProductTranslation {
  id          String   @id @default(uuid())
  product_id  String
  language_id Int
  name        String
  description String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  product  Product  @relation(fields: [product_id], references: [id])
  language Language @relation(fields: [language_id], references: [id])

  @@unique([product_id, language_id])
  @@index([product_id])
  @@index([language_id])
  @@map("product_translations")
}

model Order {
  id               String      @id @default(uuid())
  user_id          String
  total            Decimal     @db.Decimal(12, 2)
  status           OrderStatus @default(NEW)
  delivery_address String?
  contact_phone    String?
  contact_email    String?
  comment          String?
  internal_note    String?
  created_at       DateTime    @default(now())
  updated_at       DateTime    @updatedAt

  user  User        @relation(fields: [user_id], references: [id])
  items OrderItem[]

  @@index([user_id])
  @@map("orders")
}

model OrderItem {
  id         String   @id @default(uuid())
  order_id   String
  product_id String
  quantity   Int
  price      Decimal  @db.Decimal(10, 2)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  order   Order   @relation(fields: [order_id], references: [id])
  product Product @relation(fields: [product_id], references: [id])

  @@index([order_id])
  @@index([product_id])
  @@map("order_items")
}

// --- New Models (Unique Item Tracking System) ---

enum Role {
  USER
  ADMIN
  MANAGER
  SALES_MANAGER
  FRANCHISEE
}

enum OrderStatus {
  NEW
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ItemStatus {
  NEW
  REJECTED
  STOCK_HQ
  STOCK_ONLINE
  ON_CONSIGNMENT
  SOLD_ONLINE
  ACTIVATED
}

enum SalesChannel {
  OFFLINE_POINT
  MARKETPLACE
  DIRECT_SITE
}

enum LedgerOperation {
  ROYALTY_CHARGE
  SALES_PAYOUT
  WITHDRAWAL
  MANUAL_ADJ
}

enum CollectionWorkflowStatus {
  OPEN
  IN_PROGRESS
  IN_TRANSIT
  RECEIVED
  IN_STOCK
  CANCELLED
}

enum VideoProcessingJobStatus {
  UPLOADED
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum BatchVideoExportStatus {
  OPEN
  UPLOADING
  COMPLETED
  FAILED
  CANCELLED
  ABANDONED
}

model User {
  id              String   @id @default(uuid())
  name            String
  email           String?  @unique
  username        String?  @unique
  password_hash   String?
  role            Role     @default(USER)
  balance         Decimal  @default(0) @db.Decimal(12, 2)
  commission_rate Decimal  @default(0) @db.Decimal(5, 2)
  details         Json?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  // Relations
  orders                       Order[]
  batches                      Batch[]             @relation("BatchOwner")
  ledgers                      Ledger[]
  audit_logs                   AuditLog[]
  created_collection_requests  CollectionRequest[] @relation("CollectionRequestCreatedBy")
  target_collection_requests   CollectionRequest[] @relation("CollectionRequestTargetUser")
  accepted_collection_requests CollectionRequest[] @relation("CollectionRequestAcceptedBy")
  requested_video_jobs         VideoProcessingJob[] @relation("VideoProcessingRequestedBy")
  requested_video_exports      BatchVideoExportSession[] @relation("BatchVideoExportRequestedBy")

  @@map("users")
}

model Batch {
  id                    String                   @id @default(uuid())
  owner_id              String
  product_id            String?
  collection_request_id String?                  @unique
  video_url             String?
  gps_lat               Float?
  gps_lng               Float?
  collected_date        DateTime?
  collected_time        String?                  @db.VarChar(5)
  daily_batch_seq       Int?
  status                CollectionWorkflowStatus @default(IN_PROGRESS)
  created_at            DateTime                 @default(now())
  updated_at            DateTime                 @updatedAt

  owner              User               @relation("BatchOwner", fields: [owner_id], references: [id])
  product            Product?           @relation(fields: [product_id], references: [id])
  collection_request CollectionRequest? @relation(fields: [collection_request_id], references: [id])
  items              Item[]
  video_processing_jobs VideoProcessingJob[]
  video_export_sessions BatchVideoExportSession[]

  @@index([owner_id])
  @@index([product_id])
  @@index([status])
  @@map("batches")
}

model Item {
  id              String        @id @default(uuid())
  batch_id        String
  product_id      String?
  temp_id         String
  public_token    String        @unique
  serial_number   String?       @unique
  item_seq        Int?
  photo_url       String?
  item_photo_url  String?
  item_video_url  String?
  status          ItemStatus    @default(NEW)
  is_sold         Boolean       @default(false)
  sales_channel   SalesChannel?
  activation_date DateTime?
  price_sold      Decimal?      @db.Decimal(12, 2)
  commission_hq   Decimal?      @db.Decimal(12, 2)
  collected_date  DateTime?
  collected_time  String?       @db.VarChar(5)
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt

  batch          Batch    @relation(fields: [batch_id], references: [id])
  product        Product? @relation(fields: [product_id], references: [id])
  ledger_entries Ledger[]

  @@unique([batch_id, temp_id])
  @@index([batch_id])
  @@index([product_id])
  @@index([public_token])
  @@index([status, is_sold])
  @@map("items")
}

model VideoProcessingJob {
  id                     String                   @id @default(uuid())
  batch_id               String
  requested_by_user_id   String
  status                 VideoProcessingJobStatus @default(UPLOADED)
  version                Int
  source_count           Int
  output_count           Int
  processed_output_count Int                      @default(0)
  base_clip_name         String                   @db.VarChar(255)
  source_manifest        Json
  result_manifest        Json?
  error_message          String?                  @db.Text
  started_at             DateTime?
  finished_at            DateTime?
  created_at             DateTime                 @default(now())
  updated_at             DateTime                 @updatedAt

  batch             Batch @relation(fields: [batch_id], references: [id])
  requested_by_user User  @relation("VideoProcessingRequestedBy", fields: [requested_by_user_id], references: [id])

  @@unique([batch_id, version])
  @@index([batch_id, created_at])
  @@index([status])
  @@map("video_processing_jobs")
}

model BatchVideoExportSession {
  id                 String                 @id @default(uuid())
  batch_id           String
  created_by_user_id String
  status             BatchVideoExportStatus @default(OPEN)
  version            Int
  expected_count     Int
  uploaded_count     Int                    @default(0)
  crossfade_ms       Int
  source_fingerprint Json?
  render_manifest    Json?
  uploaded_manifest  Json?
  error_message      String?                @db.Text
  started_at         DateTime?
  finished_at        DateTime?
  created_at         DateTime               @default(now())
  updated_at         DateTime               @updatedAt

  batch             Batch @relation(fields: [batch_id], references: [id])
  created_by_user   User  @relation("BatchVideoExportRequestedBy", fields: [created_by_user_id], references: [id])

  @@unique([batch_id, version])
  @@index([batch_id, created_at])
  @@index([status])
  @@map("batch_video_export_sessions")
}

model Ledger {
  id        String          @id @default(uuid())
  user_id   String
  item_id   String?
  operation LedgerOperation
  amount    Decimal         @db.Decimal(12, 2)
  timestamp DateTime        @default(now())

  user User  @relation(fields: [user_id], references: [id])
  item Item? @relation(fields: [item_id], references: [id])

  @@index([user_id])
  @@map("ledger")
}

model AuditLog {
  id        String   @id @default(uuid())
  user_id   String
  action    String
  details   Json?
  timestamp DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@map("audit_logs")
}

model ContentPage {
  id         String   @id @default(uuid())
  key        String   @unique
  data       Json
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("content_pages")
}

model CollectionRequest {
  id             String                   @id @default(uuid())
  created_by     String
  target_user_id String?
  accepted_by    String?
  product_id     String?
  title          String
  note           String?
  requested_qty  Int
  status         CollectionWorkflowStatus @default(OPEN)
  accepted_at    DateTime?
  created_at     DateTime                 @default(now())
  updated_at     DateTime                 @updatedAt

  created_by_user  User     @relation("CollectionRequestCreatedBy", fields: [created_by], references: [id])
  target_user      User?    @relation("CollectionRequestTargetUser", fields: [target_user_id], references: [id])
  accepted_by_user User?    @relation("CollectionRequestAcceptedBy", fields: [accepted_by], references: [id])
  product          Product? @relation(fields: [product_id], references: [id])
  batch            Batch?

  @@index([created_by])
  @@index([target_user_id])
  @@index([accepted_by])
  @@index([product_id])
  @@index([status])
  @@index([created_at])
  @@map("collection_requests")
}
