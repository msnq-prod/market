{
  "appId": "com.stones.videohelper",
  "productName": "ZAGARAMI Video Helper",
  "artifactName": "ZAGARAMI-Video-Helper-${version}-${arch}.${ext}",
  "directories": {
    "output": "dist-electron"
  },
  "extraMetadata": {
    "main": "video-export-helper/desktop/main.cjs"
  },
  "files": [
    "video-export-helper/**/*",
    "package.json",
    "node_modules/ffmpeg-static/**/*",
    "node_modules/ffprobe-static/**/*"
  ],
  "asarUnpack": [
    "node_modules/ffmpeg-static/**/*",
    "node_modules/ffprobe-static/**/*"
  ],
  "mac": {
    "target": [
      {
        "target": "dmg",
        "arch": [
          "arm64",
          "x64"
        ]
      }
    ],
    "category": "public.app-category.video",
    "extendInfo": {
      "LSUIElement": true
    }
  }
}
