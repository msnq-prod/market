# Server
PORT=3001
CLIENT_URL=http://localhost:5173

# Database
DATABASE_URL="mysql://stones:stones@localhost:3307/stones?connection_limit=20&pool_timeout=30"

# Auth
ACCESS_TOKEN_SECRET="replace_with_a_long_random_access_secret"
REFRESH_TOKEN_SECRET="replace_with_a_long_random_refresh_secret"
TELEGRAM_TOKEN_ENCRYPTION_KEY="replace_with_32_byte_or_longer_secret"
# Optional auth tuning for local development
# AUTH_ACCESS_TOKEN_TTL_MINUTES=10
# AUTH_REFRESH_SESSION_TTL_DAYS=30
# AUTH_ALLOW_LEGACY_LOCAL_PASSWORDS=1
# TELEGRAM_WORKER_POLL_MS=5000
# TELEGRAM_WORKER_RETRY_BASE_MS=5000
# TELEGRAM_WORKER_MAX_ATTEMPTS=5

# Frontend dev server
VITE_HOST=127.0.0.1
VITE_PORT=5173
VITE_API_TARGET=http://127.0.0.1:3001
# Optional override for the local admin video helper endpoint
# VITE_VIDEO_EXPORT_HELPER_URL=http://127.0.0.1:3012
# Build-time URL for downloading the desktop video helper
VITE_VIDEO_HELPER_DOWNLOAD_URL=https://zagarami.com/uploads/downloads/ZAGARAMI-Video-Helper.dmg
VITE_VIDEO_HELPER_DOWNLOAD_URL_ARM64=https://zagarami.com/uploads/downloads/ZAGARAMI-Video-Helper-arm64.dmg

# Production helper packaging
STONES_HELPER_ALLOWED_ORIGIN=https://zagarami.com

# E2E (optional)
E2E_USE_EXISTING_SERVER=0
E2E_BASE_URL=http://127.0.0.1:5273
